# ============================================
# STEP 7: CLEAN DATA - KEEP ONLY BEST REPLICATES
# ============================================

# Identify best replicates (highest variant calls)
best_replicates <- variant_counts %>%
  mutate(Base_name = gsub("_[0-9B_]+$", "", Sample_ID),
         Base_name = gsub("_B", "", Base_name)) %>%
  group_by(Base_name) %>%
  slice_max(Variants_Called, n = 1, with_ties = FALSE) %>%
  ungroup()

# Filter genotype matrix
gl_data <- read.table("pntest_mean_gl_new.txt", header=FALSE)
gl_data <- gl_data[,-1]
all_sample_names_filtered <- all_sample_names[all_sample_names != "maniculatus"]
