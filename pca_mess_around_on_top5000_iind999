# Re-run PCA on cleaned data
gl_t <- t(gl_data_filtered)
constant_cols <- apply(gl_t, 2, function(x) sd(x, na.rm=TRUE)==0 | length(unique(x))==1)
gl_t_filtered <- gl_t[, !constant_cols]
for(i in 1:ncol(gl_t_filtered)) {
  if(any(is.na(gl_t_filtered[,i]))) gl_t_filtered[is.na(gl_t_filtered[,i]), i] <- mean(gl_t_filtered[,i], na.rm=TRUE)
}
pca_clean <- prcomp(gl_t_filtered, center=TRUE, scale=TRUE)
var_exp_clean <- summary(pca_clean)$importance[2, 1:3] * 100

pca_clean_df <- data.frame(PC1=pca_clean$x[,1], PC2=pca_clean$x[,2], PC3=pca_clean$x[,3], Individual=rownames(pca_clean$x))
pca_clean_df <- merge(pca_clean_df, q_matrix_filtered, by="Individual", all.x=TRUE)

