# ============================================
# STEP 1: INITIAL PCA WITH RAW DATA (pca_on5000snps_ind999)
# ============================================

# Load data
gl_data <- read.table("pntest_mean_gl_new.txt", header=FALSE)
locus_names <- gl_data[,1]
gl_data <- gl_data[,-1]
locus_names <- make.unique(as.character(locus_names))
locus_names[is.na(locus_names)] <- paste0("locus_", which(is.na(locus_names)))
rownames(gl_data) <- locus_names

# Transpose and clean
gl_t <- t(gl_data)
constant_cols <- apply(gl_t, 2, function(x) length(unique(x)) == 1)
gl_t_filtered <- gl_t[, !constant_cols]
gl_t_filtered[is.na(gl_t_filtered)] <- mean(gl_t_filtered, na.rm=TRUE)

# Run PCA
pca <- prcomp(gl_t_filtered, scale=TRUE, center=TRUE)
var_exp <- summary(pca)$importance[2, 1:10] * 100
var_exp_df <- data.frame(PC = paste0("PC", 1:10), Variance = var_exp[1:10])

# PCA data frame
pca_df <- data.frame(
  PC1 = pca$x[,1], PC2 = pca$x[,2], PC3 = pca$x[,3], PC4 = pca$x[,4],
  Individual = rownames(pca$x)
)

# Load sample names
ind_info <- read.table("inds_peromyscus_plus_maniculatus_filtered.txt", header=FALSE)
pca_df$Individual <- ind_info$V1[1:nrow(pca_df)]

# GRAPH 1: PC1 vs PC2 colored by species
pca_df$Species <- "Unknown"
pca_df$Species[grepl("maniculatus", pca_df$Individual, ignore.case=TRUE)] <- "maniculatus"
pca_df$Species[grepl("peromyscus", pca_df$Individual, ignore.case=TRUE)] <- "peromyscus"

p1 <- ggplot(pca_df, aes(x=PC1, y=PC2, color=Species)) +
  geom_point(size=3, alpha=0.7) +
  scale_color_manual(values=c("maniculatus"="red","peromyscus"="blue","Unknown"="gray")) +
  labs(title="PCA: PC1 vs PC2", x=paste0("PC1 (",round(var_exp[1],2),"%)"), y=paste0("PC2 (",round(var_exp[2],2),"%)"))
ggsave("1_initial_PC1_vs_PC2.pdf", p1, width=10, height=8)

# GRAPH 2: PC2 vs PC3
p2 <- ggplot(pca_df, aes(x=PC2, y=PC3, color=Species)) +
  geom_point(size=3, alpha=0.7) +
  scale_color_manual(values=c("maniculatus"="red","peromyscus"="blue","Unknown"="gray")) +
  labs(title="PCA: PC2 vs PC3", x=paste0("PC2 (",round(var_exp[2],2),"%)"), y=paste0("PC3 (",round(var_exp[3],2),"%)"))
ggsave("2_initial_PC2_vs_PC3.pdf", p2, width=10, height=8)

# GRAPH 3: Density along PC1
p3 <- ggplot(pca_df, aes(x=PC1, fill=Species)) +
  geom_density(alpha=0.5) +
  scale_fill_manual(values=c("maniculatus"="red","peromyscus"="blue","Unknown"="gray"))
ggsave("3_initial_PC1_density.pdf", p3, width=10, height=6)

# GRAPH 4: Scree plot
p4 <- ggplot(var_exp_df[1:10,], aes(x=PC, y=Variance)) +
  geom_bar(stat="identity", fill="steelblue") +
  theme(axis.text.x=element_text(angle=45,hjust=1))
ggsave("4_scree_plot.pdf", p4, width=8, height=6)

# GRAPH 5: Cumulative variance
var_exp_cum <- cumsum(var_exp)
cum_var_df <- data.frame(PC=paste0("PC",1:10), Cumulative_Variance=var_exp_cum[1:10])
p5 <- ggplot(cum_var_df, aes(x=PC, y=Cumulative_Variance, group=1)) +
  geom_line(linewidth=1.2, color="steelblue") + geom_point(size=3, color="steelblue")
ggsave("5_cumulative_variance.pdf", p5, width=8, height=6)

# ============================================
# STEP 2: CREATE ADMIXTURE CATEGORIES
# ============================================

q_table <- read.table("peromyscus_plus_maniculatus_filtered_admixture_ready.2.Q")
colnames(q_table) <- c("Ancestry1", "Ancestry2")
q_se <- read.table("peromyscus_plus_maniculatus_filtered_admixture_ready.2.Q_se")
colnames(q_se) <- c("Ancestry1_SE", "Ancestry2_SE")

fam <- read.table("peromyscus_plus_maniculatus_filtered_admixture_ready.fam")
q_table$Individual_ID <- fam$V2

# Calculate CIs
q_table$Ancestry1_CI_upper <- pmin(1, q_table$Ancestry1 + 1.96 * q_se$Ancestry1_SE)
q_table$Ancestry2_CI_upper <- pmin(1, q_table$Ancestry2 + 1.96 * q_se$Ancestry2_SE)

# Assign categories (corrected logic)
q_table$Category <- "Hybrid"
touches_leucopus <- q_table$Ancestry1_CI_upper >= 0.9999
touches_maniculatus <- q_table$Ancestry2_CI_upper >= 0.9999
q_table$Category[touches_leucopus & !touches_maniculatus] <- "P._leucopus"
q_table$Category[touches_maniculatus & !touches_leucopus] <- "P._maniculatus"

write.table(q_table[,c("Individual_ID","Category")], "sample_categories.txt", row.names=F, quote=F, sep="\t")

# ============================================
# STEP 3: PCA WITH ADMIXTURE CATEGORIES (using pntest_mean_gl_new.txt)
# ============================================

