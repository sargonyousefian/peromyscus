#!/bin/bash
#SBATCH --time=4:00:00
#SBATCH --mem=8G
#SBATCH --cpus-per-task=1
#SBATCH --job-name=sra_download
#SBATCH --mail-user=sargon.yousefian@gmail.com
#SBATCH --mail-type=ALL

module load sra-toolkit

cd /home/sydt/scratch/mgpl_file/final_results/maniculatus

# List of accessions (no spaces around =)
accessions="SRR35733630 SRR35733634 SRR35733636 SRR35733637 SRR35733639"

for accession in $accessions; do
    echo "Starting download of $accession at $(date)"
    fastq-dump --split-files --gzip $accession
    echo "Completed $accession at $(date)"
done

echo "All downloads completed!"
