cat << 'EOF' > select_diagnostic_snps_complete.sh
#!/bin/bash

# Complete script to select top 5000 diagnostic SNPs from ADMIXTURE results
# Usage: ./select_diagnostic_snps_complete.sh <dataset_name> (e.g., ind999 or ind995)

DATASET=$1

if [ -z "$DATASET" ]; then
    echo "Usage: $0 <dataset_name>"
    echo "Example: $0 ind999"
    exit 1
fi

echo "=== Selecting top 5000 diagnostic SNPs for $DATASET ==="

# Load required modules
module load plink

# Input files
P_FILE="peromyscus_${DATASET}_admixture_ready.2.P"
BIM_FILE="peromyscus_${DATASET}_admixture_ready.bim"
PLINK_PREFIX="peromyscus_${DATASET}_admixture_ready"

# Check input files exist
if [ ! -f "$P_FILE" ] || [ ! -f "$BIM_FILE" ]; then
    echo "Error: Input files not found!"
    echo "Looking for: $P_FILE and $BIM_FILE"
    exit 1
fi

echo "Step 1: Calculating diagnostic metrics..."

# Create temporary files
TEMP_COMBINED=$(mktemp)
TEMP_WITH_FST=$(mktemp)

# Combine .bim and .P files
paste $BIM_FILE $P_FILE > $TEMP_COMBINED

# Calculate diagnostic metrics
awk 'BEGIN{OFS="\t"} {
    p1 = $7  # Pop1 frequency
    p2 = $8  # Pop2 frequency
    
    # Calculate absolute difference
    delta = (p1 > p2) ? p1 - p2 : p2 - p1
    
    # Calculate diagnostic metric
    avg_freq = (p1 + p2) / 2
    if (avg_freq < 0.01) avg_freq = 0.01
    diagnostic = delta / (avg_freq * (1 - avg_freq) + 0.001)
    
    print $0, delta, diagnostic
}' $TEMP_COMBINED > $TEMP_WITH_FST

echo "Step 2: Selecting top 5000 SNPs..."

# Sort by diagnostic metric and take top 5000
sort -k10,10nr $TEMP_WITH_FST | head -5000 > ${DATASET}_top5000_diagnostic_snps.txt

# Create position-based SNP IDs (CHR:POS format)
awk 'BEGIN{OFS=":"} {print $1, $4}' ${DATASET}_top5000_diagnostic_snps.txt > ${DATASET}_top5000_snp_positions.txt

echo "Step 3: Creating PLINK files with proper SNP IDs..."

# Create new .bim file with CHR:POS as SNP IDs
awk 'BEGIN{OFS="\t"} {$2 = $1":"$4; print}' $BIM_FILE > ${PLINK_PREFIX}_fixed.bim
cp ${PLINK_PREFIX}.bed ${PLINK_PREFIX}_fixed.bed
cp ${PLINK_PREFIX}.fam ${PLINK_PREFIX}_fixed.fam

echo "Step 4: Extracting top 5000 SNPs with PLINK..."

# Extract the top 5000 diagnostic SNPs
plink --bfile ${PLINK_PREFIX}_fixed --extract ${DATASET}_top5000_snp_positions.txt --make-bed --out peromyscus_${DATASET}_top5000_final

# Clean up temporary files
rm $TEMP_COMBINED $TEMP_WITH_FST

# Get statistics
MEAN_DIAGNOSTIC=$(awk '{sum+=$10; count++} END {print sum/count}' ${DATASET}_top5000_diagnostic_snps.txt)
MEAN_DELTA=$(awk '{sum+=$9; count++} END {print sum/count}' ${DATASET}_top5000_diagnostic_snps.txt)

echo ""
echo "=== RESULTS FOR $DATASET ==="
echo "✓ Top 5000 diagnostic SNPs selected"
echo "✓ Mean diagnostic metric: $MEAN_DIAGNOSTIC"
echo "✓ Mean allele frequency difference: $MEAN_DELTA"

# Verify final results
if [ -f "peromyscus_${DATASET}_top5000_final.bim" ]; then
    FINAL_SNP_COUNT=$(wc -l < peromyscus_${DATASET}_top5000_final.bim)
    echo "✓ Final SNP count: $FINAL_SNP_COUNT"
    echo "✓ Final PLINK files created successfully"
    
    echo ""
    echo "Files ready for entropy analysis:"
    ls -lh peromyscus_${DATASET}_top5000_final.{bed,bim,fam}
else
    echo "✗ Error: Final PLINK files not created"
fi

echo ""
echo "Top 5 most diagnostic SNPs:"
echo "CHR:POS	Pop1_freq	Pop2_freq	Delta	Diagnostic"
head -5 ${DATASET}_top5000_diagnostic_snps.txt | awk '{print $1":"$4, $7, $8, $9, $10}'

EOF

chmod +x select_diagnostic_snps_complete.sh
