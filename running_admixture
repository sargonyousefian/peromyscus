# cannot run jobs longer than 7 days on compute canada, so I cannot run entropy on all my SNPs and inviduals. I will be running admixture first and then grab the top diagnostic markers and run entropy on those
# first i need to conver my .vcf file for admixture, i will use plink
# --double-id is because some ID have underscore, --allow-extra-chr and --ch-set is because of issues with the chromosome naming from NCBI

Module load plink
Module load admixture

plink --vcf peromyscus_plus_maniculatus_filtered.vcf \
      --double-id \
      --allow-extra-chr \
      --chr-set 95 \
      --make-bed \
      --out peromyscus_plus_maniculatus_filtered_fresh

awk 'BEGIN{OFS="\t"} {
    if (!chr_map[$1]) {
        chr_map[$1] = ++chr_count
    }
    $1 = chr_map[$1]
    print
}' peromyscus_plus_maniculatus_filtered_fresh.bim > peromyscus_plus_maniculatus_filtered_admixture_ready.bim

cp peromyscus_plus_maniculatus_filtered_fresh.bed peromyscus_plus_maniculatus_filtered_admixture_ready.bed
cp peromyscus_plus_maniculatus_filtered_fresh.fam peromyscus_plus_maniculatus_filtered_admixture_ready.fam

### -B gives me confidence intervals for the samples
for K in 2 3; do
    echo "Running ADMIXTURE with bootstrapping for K=$K at $(date)"
    admixture -B --cv peromyscus_plus_maniculatus_filtered_admixture_ready.bed $K -j${SLURM_CPUS_PER_TASK}
    echo "Finished K=$K at $(date)"
done

echo "All ADMIXTURE runs complete at $(date)"
